# OPENAI_MODEL=gpt-4o

DATABASE_URL=postgresql://sehra:sehra_pass@localhost:5432/sehra_db

# Share link base URL (set to your Railway deployment URL in production)
APP_URL=http://localhost:8501

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
